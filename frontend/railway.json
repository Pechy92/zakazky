{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "npm run build",
    "watchPatterns": [
      "Radek/webApp/Zakázky/frontend/src/**",
      "Radek/webApp/Zakázky/frontend/package.json",
      "Radek/webApp/Zakázky/frontend/vite.config.ts",
      "Radek/webApp/Zakázky/frontend/tsconfig.json"
    ]
  },
  "deploy": {
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
