# Database
DATABASE_URL=postgresql://user:password@localhost:5432/zakazky

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key

# Port
PORT=3001

# Node environment
NODE_ENV=development

# CORS frontend URL
FRONTEND_URL=http://localhost:3000

# Upload storage root directory (for PDF files)
# Local example: ./uploads
# Railway with Volume mount: /data/uploads
UPLOAD_DIR=./uploads

# ARES API (pro vyhledávání firem podle IČ)
ARES_API_URL=https://ares.gov.cz/ekonomicke-subjekty-v-be/rest/ekonomicke-subjekty

# Optional PDF settings
# PDF_LOGO_URL=https://your-cdn/logo.png
# CHROME_PATH=/usr/bin/chromium
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
